# --- PostgreSQL ---
POSTGRES_USER=newsbot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=newsbot
DATABASE_URL=postgresql+psycopg2://newsbot:change-me@postgres:5432/newsbot

# --- Redis / Celery broker ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me-too-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Encrypts TELEGRAM_BOT_TOKEN / AI_API_KEY at rest once they're stored in the
# database (see below). Required before the stack will start. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# --- Telegram / AI ---
# These are only the *initial seed* value, copied into the encrypted
# `settings` table the first time the stack boots. After that, edit them in
# the web panel under Settings (admin role) — that's the source of truth,
# not this file. Changing the bot token there still requires
# `docker compose restart bot` (long-polling can't hot-swap tokens); AI
# credential changes apply immediately.
TELEGRAM_BOT_TOKEN=
# Numeric chat_id of the target channel the bot posts to (bot must be an admin there)
TARGET_CHANNEL_ID=

# openai | anthropic | custom_openai_compatible
AI_PROVIDER=openai
AI_API_KEY=
# Only used when AI_PROVIDER=custom_openai_compatible (self-hosted / YandexGPT-compatible gateway / etc.)
AI_API_BASE=
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=800

# --- Media storage ---
MEDIA_ROOT=/app/media

# --- Misc ---
ENV=production
LOG_LEVEL=INFO
